# Application
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-char-string

# Database
DATABASE_URL=postgresql://axiomedge:axiomedge@postgres:5432/axiomedge
DATABASE_URL_RO=postgresql://axiomedge:axiomedge@postgres:5432/axiomedge

# Redis
REDIS_URL=redis://redis:6379
MARKET_DATA_PROVIDER=tradingview

# Object storage (S3-compatible)
S3_BUCKET=axiomedge
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Encryption & secrets
KMS_MASTER_KEY=
TRADINGVIEW_SESSION_ENC=

# Broker OAuth (Alpaca)
ALPACA_CLIENT_ID=
ALPACA_CLIENT_SECRET=
ALPACA_REDIRECT_URI=http://localhost:3000/api/broker/oauth/alpaca/callback

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Observability
SENTRY_DSN=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Docker Compose (optional overrides)
APP_PORT=3000
POSTGRES_USER=axiomedge
POSTGRES_PASSWORD=axiomedge
POSTGRES_DB=axiomedge
POSTGRES_PORT=5432
REDIS_PORT=6379
